{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "vite.config.ts"],
  "references": [
    { "path": "../../lib/api-client-react" },
    { "path": "../../lib/api-zod" }
  ]
}
